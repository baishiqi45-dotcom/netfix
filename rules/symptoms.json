    {
      "id": "local-wifi-issue",
      "keywords": ["wifi", "packet loss", "gateway", "latency"],
      "diagnostics": ["path_trace", "wifi_signal", "gateway"],
      "root_causes": [
        {"id": "local-wifi-issue", "description": "本地第一跳丢包或延迟高，Wi-Fi/网关存在问题", "confidence": 0.8}
      ],
      "fixes": [],
      "manual_steps": [
        "靠近路由器或切换到 5GHz 频段",
        "重启路由器",
        "检查是否有其他设备占用大量带宽"
      ]
    }
  ],
  "fixes": {
    "flush-dns-cache": {
      "tier": 1,
      "platforms": ["darwin"],
      "description": "刷新 macOS DNS 缓存",
      "commands": [
        "sudo dscacheutil -flushcache",
        "sudo killall -HUP mDNSResponder"
      ],
      "verify": "scutil --dns",
      "verify_diagnostic": "dns_local",
      "backup_paths": [],
      "reverse": []
    },
    "reset-system-proxy": {
      "tier": 2,
      "platforms": ["darwin"],
      "description": "重置 macOS 系统代理（先关闭再让 GUI 重新应用）",
      "commands": [
        "networksetup -setwebproxystate 'Wi-Fi' off",
        "networksetup -setsecurewebproxystate 'Wi-Fi' off",
        "networksetup -setsocksfirewallproxystate 'Wi-Fi' off"
      ],
      "verify": "scutil --proxy",
      "verify_diagnostic": "system_proxy_state",
      "backup_paths": [],
      "reverse": [
        "echo '请手动在 GUI 客户端重新应用系统代理'"
      ]
    },
    "disable-auto-proxy": {
      "tier": 2,
      "platforms": ["darwin"],
      "description": "关闭 macOS PAC/WPAD 自动代理，保留手动代理",
      "commands": [
        "networksetup -setautoproxystate 'Wi-Fi' off",
        "networksetup -setproxyautodiscovery 'Wi-Fi' off"
      ],
      "verify": "scutil --proxy",
      "verify_diagnostic": "system_proxy_state",
      "backup_paths": [],
      "reverse": [
        "networksetup -setautoproxystate 'Wi-Fi' on",
        "networksetup -setproxyautodiscovery 'Wi-Fi' on"
      ]
    },
    "check-proxy-core": {
      "tier": 1,
      "description": "检测代理核心是否运行并监听 mixed 端口",
      "commands": [
        "lsof -nP -iTCP:10808 -sTCP:LISTEN"
      ],
      "verify": "lsof -nP -iTCP:10808 -sTCP:LISTEN",
      "backup_paths": [],
      "reverse": []
    },
    "renew-dhcp": {
      "tier": 1,
      "platforms": ["darwin"],
      "description": "强制当前接口重新获取 DHCP 租约",
      "commands": [
        "sudo ipconfig set en0 DHCP"
      ],
      "verify": "ipconfig getpacket en0",
      "verify_diagnostic": "dhcp_state",
      "backup_paths": [],
      "reverse": []
    },
    "disable-ipv6": {
      "tier": 2,
      "platforms": ["darwin"],
      "description": "关闭所有网络服务的 IPv6 以防止泄漏",
      "commands": [
        "sudo bash bin/disable_ipv6.sh"
      ],
      "verify_diagnostic": "ipv6_leak",
      "backup_paths": [],
      "reverse": [
        "sudo bash bin/enable_ipv6.sh"
      ]
    },
    "set-public-dns": {
      "tier": 2,
      "platforms": ["darwin"],
      "description": "将 Wi-Fi DNS 设置为公共 DNS",
      "commands": [
        "networksetup -setdnsservers 'Wi-Fi' 1.1.1.1 8.8.8.8"
      ],
      "verify": "scutil --dns",
      "verify_diagnostic": "dns_leak",
      "backup_paths": [],
      "reverse": [
        "networksetup -setdnsservers 'Wi-Fi' empty"
      ]
    }
  }
}
