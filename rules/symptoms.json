        {"id": "pf-rule", "description": "pf 包过滤规则丢弃流量", "confidence": 0.5}
      ],
      "fixes": [],
      "manual_steps": [
        "检查系统设置 > 隐私与安全 > 防火墙",
        "执行 socketfilterfw --add /Applications/YourApp.app",
        "检查 pfctl -sr 规则"
      ]
    },
    {
      "id": "ai-service-ip-blocked",
      "keywords": ["openai", "chatgpt", "claude", "anthropic", "403", "blocked", "风控"],
      "diagnostics": ["codex_api_via_proxy", "node_reachability"],
      "root_causes": [
        {"id": "node-flagged", "description": "当前代理节点 IP 被 AI 服务风控或拉黑", "confidence": 0.8}
      ],
      "fixes": [],
      "manual_steps": [
        {
          "id": "switch-node",
          "description": "切换到其他代理节点",
          "steps": [
            "打开你的代理客户端（v2rayN / Clash / Surge）",
            "选择一个不同地区或类型的节点",
            "刷新浏览器或重启 AI 应用后重试"
          ]
        },
        {
          "id": "disable-ipv6",
          "description": "禁用 IPv6 防止泄漏",
          "steps": [
            "系统设置 > 网络 > 当前连接 > 详细信息",
            "将 IPv6 设为「关闭」或「仅本地链接」",
            "或在代理客户端开启「IPv6 关闭」选项"
          ]
        },
        {
          "id": "disable-quic",
          "description": "关闭浏览器 HTTP/3 QUIC",
          "steps": [
            "Chrome/Edge 地址栏输入 chrome://flags/#enable-quic",
            "将 Experimental QUIC protocol 设为 Disabled",
            "重启浏览器"
          ]
        }
      ]
    },
